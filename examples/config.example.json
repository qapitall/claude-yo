{
  "mode": "on-demand",
  "provider": "ntfy",
  "ntfy": {
    "topic": "cwn-replace-with-your-long-random-topic",
    "server": "https://ntfy.sh",
    "authToken": null
  },
  "discord": {
    "webhookUrl": null
  },
  "telegram": {
    "botToken": null,
    "chatId": null
  },
  "filters": {
    "minDurationSeconds": 30,
    "events": ["Stop", "Notification"]
  },
  "quietHours": {
    "enabled": false,
    "start": "23:00",
    "end": "08:00",
    "allowHighPriority": true
  },
  "summary": {
    "maxLength": 100,
    "includeProjectName": true
  }
}
